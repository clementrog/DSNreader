    préavis de fin de contrat:
      applicable si: salarié . contrat . fin de contrat
      titre: S21.G00.63 - Préavis de fin de contrat
      avec:
        type réalisation et paiement du préavis:
          titre: S21.G00.63.001
          valeur:
            variations:
              - si: salarié . contrat . fin de contrat . motif de fin de contrat . rupture de période d'essai
                alors: "'90'"
              - si: salarié . contrat . fin de contrat . motif de fin de contrat . licenciement
                alors:
                  variations:
                    - si: salarié . contrat . fin de contrat . motif de fin de contrat . licenciement . faute . grave
                      alors: "'90'"
                    - sinon: salarié . contrat . fin de contrat . motif de fin de contrat . licenciement . préavis . type de réalisation et paiement du préavis
              - si: salarié . contrat . fin de contrat . motif de fin de contrat . mise à la retraite
                alors: salarié . contrat . fin de contrat . motif de fin de contrat . mise à la retraite . préavis . type de réalisation et paiement du préavis
              - si: salarié . contrat . fin de contrat . motif de fin de contrat . démission
                alors: salarié . contrat . fin de contrat . motif de fin de contrat . démission . préavis . type de réalisation et paiement du préavis
              - si: salarié . contrat . fin de contrat . motif de fin de contrat . rupture conventionnelle individuelle
                alors: "'90'"
              - si: salarié . contrat . fin de contrat . motif de fin de contrat . fin de CDD
                alors: "'90'"
              - sinon: "''"
        date de début de préavis:
          titre: S21.G00.63.002
          valeur: salarié . contrat . fin de contrat . préavis . date de début de préavis
        date de fin de préavis:
          titre: S21.G00.63.003
          valeur: salarié . contrat . fin de contrat . préavis . date de fin de préavis
    autre suspension de l'exécution du contrat:
      titre: S21.G00.65 - Autre suspension de l'exécution du contrat
      avec:
        CONGE DIVERS NON REMUNERE:
          # applicable si: salarié . absences . congés sans solde
          applicable si:
            une de ces conditions:
              - salarié . absences . congés sans solde
              - salarié . absences . absence injustifiée
          avec:
            motif de suspension:
              titre: S21.G00.65.001
              valeur: "'501'"
            date de début de la suspension:
              titre: S21.G00.65.002
              variations:
                - si: salarié . absences . congés sans solde
                  alors: salarié . absences . congés sans solde . date de début
                - si: salarié . absences . absence injustifiée
                  alors: salarié . absences . absence injustifiée . date de début
                - sinon: "''"
              # valeur: salarié . absences . congés sans solde . date de début
            date de fin de la suspension:
              titre: S21.G00.65.003
              variations:
                - si: salarié . absences . congés sans solde
                  alors: salarié . absences . congés sans solde . date de fin
                - si: salarié . absences . absence injustifiée
                  alors: salarié . absences . absence injustifiée . date de fin
                - sinon: "''"
              # valeur: salarié . absences . congés sans solde . date de fin
            position de détachement:
              titre: S21.G00.65.004
              valeur: "''"
            nombre de jours ouvrés de suspension:
              titre: S21.G00.65.005
              valeur: "''"
        CONGE EVENEMENT FAMILIAL:
          applicable si: salarié . absences . évènements familiaux non rémunérés
          avec:
            motif de suspension:
              titre: S21.G00.65.001
              valeur: "'637'"
            date de début de la suspension:
              titre: S21.G00.65.002
              valeur: salarié . absences . évènements familiaux non rémunérés . date de début
            date de fin de la suspension:
              titre: S21.G00.65.003
              valeur: salarié . absences . évènements familiaux non rémunérés . date de fin
            position de détachement:
              titre: S21.G00.65.004
              valeur: "''"
            nombre de jours ouvrés de suspension:
              titre: S21.G00.65.005
              valeur: "''"
        ACTIVITE PARTIELLE:
          applicable si: salarié . activité partielle
          avec:
            motif de suspension:
              titre: S21.G00.65.001
              valeur: "'602'"
            date de début de la suspension:
              titre: S21.G00.65.002
              valeur: salarié . activité partielle . absence . date de début
            date de fin de la suspension:
              titre: S21.G00.65.003
              valeur: salarié . activité partielle . absence . date de fin
