          applicable si: salarié . contrat . CDD
          titre: S21.G00.40.021 - Motif de recours
          valeur:
            variations:
              - si: salarié . contrat . CDD . motif . classique . usage
                alors: "'05'"
              - si: salarié . contrat . CDD . motif . classique . remplacement
                alors: "'01'"
              - si: salarié . contrat . CDD . motif . classique . accroissement activité
                alors: "'02'"
              - si: salarié . contrat . CDD . motif . classique . saisonnier
                alors: "'03'"
              - si: salarié . contrat . CDD . motif . classique . objet défini
                alors: "'06'"
