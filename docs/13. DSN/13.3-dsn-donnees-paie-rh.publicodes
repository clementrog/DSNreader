    versement organisme de protection sociale:
      titre: S21.G00.20 - Versement organisme de protection sociale
      avec:
        URSSAF:
          applicable si:
            une de ces conditions:
              - urssaf . périodicité de paiement = 'mensuelle'
              - date = 09/2025
              - date = 12/2025
              - date = 03/2026
              - date = 06/2026
              - date = 09/2026
              - date = 12/2026
              - date = 03/2027
              - date = 06/2027
              - date = 09/2027
              - date = 12/2027
          avec:
            identifiant organisme de protection sociale:
              titre: S21.G00.20.001 - Identifiant Organisme de Protection Sociale
              valeur: entreprise . urssaf . SIRET
            entité d'affectation des opérations:
              titre: S21.G00.20.002 - Entité d'affectation des opérations
              valeur: entreprise . SIRET
            bic:
              titre: S21.G00.20.003 - BIC
              valeur: urssaf . BIC
            iban:
              titre: S21.G00.20.004 - IBAN
              valeur: urssaf . IBAN
            montant du versement:
              titre: S21.G00.20.005 - Montant du versement
              # valeur: urssaf . montant du versement
              variations:
                - si: urssaf . périodicité de paiement = 'mensuelle'
                  alors: urssaf . montant du versement
                - sinon:
                    somme:
                      - urssaf . montant du versement
                      - urssaf . montant du versement @{ M-1 }
                      - urssaf . montant du versement @{ M-2 }
              arrondi: oui
            date de début de période de rattachement:
              titre: S21.G00.20.006 - Date de début de période de rattachement
              # valeur: période de paie . premier jour du mois bulletin
              variations:
                - si: urssaf . périodicité de paiement = 'mensuelle'
                  alors: période de paie . premier jour du mois bulletin
                - sinon:
                    variations:
                      - si: M = 08/2025
                        alors: "''"
                      - si: M = 09/2025
                        alors: "'01/07/2025'"
                      - si: M = 10/2025
                        alors: "''"
                      - si: M = 11/2025
                        alors: "''"
                      - si: M = 12/2025
                        alors: "'01/10/2025'"
                      - si: M = 01/2026
                        alors: "''"
                      - si: M = 02/2026
                        alors: "''"
                      - si: M = 03/2026
                        alors: "'01/01/2026'"
                      - si: M = 04/2026
                        alors: "''"
                      - si: M = 05/2026
                        alors: "''"
                      - si: M = 06/2026
                        alors: "'01/04/2026'"
                      - si: M = 07/2026
                        alors: "''"
                      - si: M = 08/2026
                        alors: "''"
                      - si: M = 09/2026
                        alors: "'01/07/2026'"
                      - si: M = 10/2026
                        alors: "''"
                      - si: M = 11/2026
                        alors: "''"
                      - si: M = 12/2026
                        alors: "'01/10/2026'"
                      - sinon: "'Error'"
            date de fin de période de rattachement:
              titre: S21.G00.20.007 - Date de fin de période de rattachement
              # valeur: période de paie . dernier jour du mois bulletin
              variations:
                - si: urssaf . périodicité de paiement = 'mensuelle'
                  alors: période de paie . dernier jour du mois bulletin
                - sinon:
                    variations:
                      - si: M = 08/2025
                        alors: "''"
                      - si: M = 09/2025
                        alors: "'30/09/2025'"
                      - si: M = 10/2025
                        alors: "''"
                      - si: M = 11/2025
                        alors: "''"
                      - si: M = 12/2025
                        alors: "'31/12/2025'"
                      - si: M = 01/2026
                        alors: "''"
                      - si: M = 02/2026
                        alors: "''"
                      - si: M = 03/2026
                        alors: "'31/03/2026'"
                      - si: M = 04/2026
                        alors: "''"
                      - si: M = 05/2026
                        alors: "''"
                      - si: M = 06/2026
                        alors: "'30/06/2026'"
                      - si: M = 07/2026
                        alors: "''"
                      - si: M = 08/2026
                        alors: "''"
                      - si: M = 09/2026
