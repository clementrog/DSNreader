                - si: retraite complémentaire . siret = '78430152500035'
                  alors:
                    variations:
                      - si: retraite complémentaire . périodicité de paiement = 'mensuelle'
                        alors: retraite complémentaire . montant du versement
                      - sinon:
                          somme:
                            - retraite complémentaire . montant du versement
                            - retraite complémentaire . montant du versement @{ M-1 }
                            - retraite complémentaire . montant du versement @{ M-2 }
                    arrondi: oui
                - sinon: 
                    variations:
                      - si: retraite complémentaire . périodicité de paiement = 'mensuelle'
                        alors: retraite complémentaire . montant du versement
                      - sinon:
                          somme:
