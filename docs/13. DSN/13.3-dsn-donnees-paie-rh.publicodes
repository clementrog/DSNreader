    contrat:
      titre: Contrat - S21.G00.40
      avec:
        date de début du contrat:
          titre: S21.G00.40.001 - Date de début du contrat
          valeur: salarié . contrat . date d'embauche
        statut du salarié conventionnel:
          titre: S21.G00.40.002 - Statut du salarié (conventionnel)
          valeur:
            variations:
              - si: salarié . contrat . cadre dirigeant
                alors: "'03'"
              - si: dirigeant
                alors: "'03'"
              - si: salarié . contrat . statut cadre
                alors: "'04'"
              - sinon: "'06'"
        code statut catégoriel retraite complémentaire obligatoire:
          titre: S21.G00.40.003 - Code statut catégoriel Retraite Complémentaire obligatoire
          valeur:
            variations:
              - si: salarié . contrat . stage
                alors: "'99'" 
              - si: salarié . contrat . statut cadre
                # alors: "'01'" 
                alors:
                  variations: 
                    - si: retraite complémentaire . siret = '78430152500035'
                      alors: "'98'"
                    - sinon: "'01'"
              - sinon: "'04'"
        code profession et catégorie socioprofessionnelle PCS ESE:
          titre: S21.G00.40.004 - Code profession et catégorie socioprofessionnelle (PCS-ESE)
          valeur: salarié . contrat . code PCS-ESE
        code complément PCS ESE pour la fonction publique:
          titre: S21.G00.40.005 - Code complément PCS-ESE pour la fonction publique
          valeur: "''"
        libellé de l'emploi:
          titre: S21.G00.40.006 - Libellé de l'emploi
          valeur: salarié . contrat . intitulé du poste
        nature du contrat:
          titre: S21.G00.40.007 - Nature du contrat
          valeur:
            variations:
              - si: dirigeant
                alors: "'80'"
              - si: salarié . contrat . CDI . chantier
                alors: "'82'"
              - si: salarié . contrat . CDI
                alors: "'01'"
              - si: salarié . contrat . CDD
                alors: "'02'"
              - si: salarié . contrat . apprentissage
                alors: "'02'"
              - si: salarié . contrat . professionnalisation
                alors: "'02'"
              - si: salarié . contrat . stage
                alors: "'29'"
              - sinon: "''"
        dispositif de politique publique et conventionnel:
          titre: S21.G00.40.008 - Dispositif de politique publique et conventionnel
          valeur:
            variations:
              - si: salarié . contrat . apprentissage
                alors: "'64'"
              - si: salarié . contrat . professionnalisation
                alors: "'61'"
              - si: salarié . contrat . stage
                alors: "'92'"
              - sinon: "'99'"
        numéro du contrat:
          titre: S21.G00.40.009 - Numéro du contrat
          valeur: salarié . contrat . numéro de contrat
        date de fin prévisionnelle du contrat:
          titre: S21.G00.40.010 - Date de fin prévisionnelle du contrat
          # valeur: salarié . contrat . apprentissage . fin de contrat prévisionnelle
          variations:
            - si: salarié . contrat . apprentissage
              alors: salarié . contrat . apprentissage . fin de contrat prévisionnelle
            - si: salarié . contrat . professionnalisation
              alors: salarié . contrat . professionnalisation . fin de contrat prévisionnelle
            - si: salarié . contrat . stage
              alors: salarié . contrat . stage . fin de stage prévisionnelle
            - sinon: "''"
        unité de mesure de la quotité de travail:
          titre: S21.G00.40.011 - Unité de mesure de la quotité de travail
          valeur:
            variations:
              - si: dirigeant
                alors: "'99'"
              - si: salarié . contrat . cadre dirigeant
                alors: "'99'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'forfait heure'
                alors: "'21'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'forfait jour'
                alors: "'20'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'heure'
                alors: "'10'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'salarié non concerné'
                alors: "'99'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'journée'
                alors: "'12'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'à la pige'
                alors: "'31'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'à la vacation'
                alors: "'32'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'à la tâche'
                alors: "'33'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'au SMIC'
                alors: "'34'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'à la part'
                alors: "'35'"
              - sinon: "''"
        quotité de travail de référence de l'entreprise pour la catégorie de salarié:
          titre: S21.G00.40.012 - Quotité de travail de référence de l'entreprise pour la catégorie de salarié
          # valeur: salarié . contrat . temps de travail . quotité de travail
          valeur:
            variations:
              - si: dirigeant
                alors: "'0.00'"
              - si: salarié . contrat . cadre dirigeant
                alors: "'0.00'"
              - si: salarié . contrat . temps de travail . unité de mesure = 'heure'
                alors: salarié . contrat . temps de travail hebdomadaire légal * période . nombre de semaines par an / période . nombre de mois par an
              - si: salarié . contrat . temps de travail . unité de mesure = 'forfait heure'
                alors: 166.83
              - si: salarié . contrat . temps de travail . unité de mesure = 'forfait jour'
                alors: 21.67
          #     # - si: salarié . contrat . temps de travail . modalité syntec . heures
          #     #   alors: 151.67
          #     # - si: salarié . contrat . temps de travail . modalité syntec . forfait heures
          #     #   alors: 166.83
          #     # - si: salarié . contrat . temps de travail . modalité syntec . forfait jours
          #     #   alors: 21.67
              - sinon: 0
        quotité de travail du contrat:
          titre: S21.G00.40.013 - Quotité de travail du contrat
          valeur: salarié . contrat . temps de travail . quotité de travail
        modalité d'exercice du temps de travail:
          titre: S21.G00.40.014 - Modalité d'exercice du temps de travail
          valeur:
            variations:
              - si: dirigeant
                alors: 99
              - si: salarié . contrat . cadre dirigeant
                alors: 99
              - si: salarié . contrat . temps de travail . temps partiel
                alors: 20
              - si: salarié . contrat . temps de travail . unité de mesure = 'forfait jour'
                alors: 10
              - si: salarié . contrat . temps de travail hebdomadaire >= 35
                alors: 10
              - sinon: "''"
        complément de base au régime obligatoire:
          titre: S21.G00.40.016 - Complément de base au régime obligatoire
          valeur:
            variations:
              - si: salarié . régimes spécifiques . alsace moselle
                alors: "'01'"
              - sinon: "'99'"
