              # applicable si:
              #   est applicable: mutuelle . numéro de contrat
              titre: S21.G00.15.004 - Personnel couvert
              # par défaut: "'01'"
              variations:
                - si: mutuelle . numéro de contrat
                  alors: "'01'"
                - sinon: "''"
              # variations:
              #   - si: mutuelle
              #     alors: "'01'"
              #   - sinon: "''"
