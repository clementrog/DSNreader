    activité:
      titre: S21.G00.53 - Activité
      avec:
        TRAVAIL REMUNERE REEL:
          # non applicable si: dirigeant
          avec:
            type:
              titre: S21.G00.53.001
              valeur: "'01'"
            mesure:
              titre: S21.G00.53.002
              valeur: salarié . temps travaillé ce mois
            unité de mesure:
              titre: S21.G00.53.003
              valeur:
                variations:
                  - si: salarié . contrat . temps de travail . unité de mesure = 'heure'
                    alors: "'10'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'journée'
                    alors: "'12'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'forfait jour'
                    alors: "'20'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'forfait heure'
                    alors: "'21'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'à la pige'
                    alors: "'31'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'à la vacation'
                    alors: "'32'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'à la tâche'
                    alors: "'33'"
                  - sinon: "''"
        TRAVAIL REMUNERE CALENDAIRE:
          avec:
            type:
              titre: S21.G00.53.001
              valeur: "'01'"
            mesure:
              titre: S21.G00.53.002
              # valeur: période de paie . jours . présence . calendaires
              valeur: période de paie . jours . présence . temps de travail effectif
            unité de mesure:
              titre: S21.G00.53.003
              valeur: "'40'"
        ABSENCE NON REMUNEREE:
          # non applicable si: dirigeant
          avec:
            type:
              titre: S21.G00.53.001
              valeur: "'02'"
            mesure:
              titre: S21.G00.53.002
              valeur:
                variations:
                  - si: salarié . contrat . temps de travail . unité de mesure = 'heure'
                    # - si: salarié . contrat . temps de travail . modalité syntec . heures
                    # alors: salarié . absences . total . heures - (salarié . absences . entrée sortie . total . nombre * salarié . contrat . horaire journalier contractuel)
                    alors: salarié . absences . heures non rémunérées - (salarié . absences . entrée sortie . total . nombre * salarié . contrat . horaire journalier contractuel)
                  - si: salarié . contrat . temps de travail . unité de mesure = 'forfait heure'
                    # - si: salarié . contrat . temps de travail . modalité syntec . forfait heures
                    # alors: salarié . absences . total . heures - (salarié . absences . entrée sortie . total . nombre * salarié . contrat . horaire journalier contractuel)
                    alors: salarié . absences . heures non rémunérées - (salarié . absences . entrée sortie . total . nombre * salarié . contrat . horaire journalier contractuel)
                  - si: salarié . contrat . temps de travail . unité de mesure = 'forfait jour'
                    # - si: salarié . contrat . temps de travail . modalité syntec . forfait jours
                    # alors: salarié . absences . total . jours - (salarié . absences . entrée sortie . total . nombre)
                    alors: salarié . absences . jours non rémunérés calendaires - (salarié . absences . entrée sortie . total . nombre)
                  - sinon: "'0.00'"
            unité de mesure:
              titre: S21.G00.53.003
              valeur:
                variations:
                  - si: salarié . contrat . temps de travail . unité de mesure = 'heure'
                    alors: "'10'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'journée'
                    alors: "'12'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'forfait jour'
                    alors: "'20'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'forfait heure'
                    alors: "'21'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'à la pige'
                    alors: "'31'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'à la vacation'
                    alors: "'32'"
                  - si: salarié . contrat . temps de travail . unité de mesure = 'à la tâche'
                    alors: "'33'"
                  - sinon: "'10'"
