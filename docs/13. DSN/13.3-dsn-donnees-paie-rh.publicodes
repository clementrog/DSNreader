        PREVOYANCE:
          avec:
            référence du contrat de prévoyance:
              titre: S21.G00.15.001 - Référence du contrat de Prévoyance
              valeur: prévoyance . référence contrat
            code organisme de prévoyance:
              titre: S21.G00.15.002 - Code organisme de Prévoyance
              valeur: prévoyance . code organisme
            code délégataire de gestion:
              titre: S21.G00.15.003 - Code délégataire de gestion
              valeur: prévoyance . code délégataire de gestion
            personnel couvert:
              # applicable si: référence du contrat de prévoyance != ""
              # applicable si:
              #   est applicable: prévoyance . référence contrat
              titre: S21.G00.15.004 - Personnel couvert
              # par défaut: "'01'"
              variations:
                - si: prévoyance . référence contrat
                  alors: "'01'"
