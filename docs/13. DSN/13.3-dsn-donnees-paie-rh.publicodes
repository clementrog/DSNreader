              valeur: "''"
            identifiant du versement:
              titre: S21.G00.20.014 - Identifiant du versement
              valeur: "''"
        AGIRC ARRCO:
          applicable si:
            une de ces conditions:
              - retraite complémentaire . périodicité de paiement = 'mensuelle'
              - date = 09/2025
              - date = 12/2025
              - date = 03/2026
              - date = 06/2026
              - date = 09/2026
              - date = 12/2026
              - date = 03/2027
              - date = 06/2027
              - date = 09/2027
              - date = 12/2027
          avec:
            identifiant organisme de protection sociale:
              titre: S21.G00.20.001 - Identifiant Organisme de Protection Sociale
              valeur: retraite complémentaire . siret
            entité d'affectation des opérations:
              titre: S21.G00.20.002 - Entité d'affectation des opérations
              variations:
                - si: retraite complémentaire . siret = '78430152500035'
                  alors: "''"
                - sinon:
                    valeur: entreprise . SIRET
            bic:
              titre: S21.G00.20.003 - BIC
              valeur: retraite complémentaire . informations bancaires . BIC
            iban:
              titre: S21.G00.20.004 - IBAN
