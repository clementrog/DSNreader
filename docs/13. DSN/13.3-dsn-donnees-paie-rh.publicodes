    composant du versement:
      titre: S21.G00.55 - Composant du versement
      avec:
        PREVOYANCE:
          avec:
            montant versé:
              titre: S21.G00.55.001
              variations:
                - si: prévoyance . périodicité de paiement = 'mensuelle'
                  alors: prévoyance . montant du versement
                - sinon:
