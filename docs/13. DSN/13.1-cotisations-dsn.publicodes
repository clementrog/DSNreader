dsn . base assujettie:
  titre: S21.G00.78 - Base assujettie
  avec:
    code de base assujettie: 
      titre: S21.G00.78.001 - Code de base assujettie
      avec:
        assiette brute déplafonnée 03:
          avec:
            # 78
            code: "'03'"
            date de début de période de rattachement:
              titre: S21.G00.78.002 - Date de début de période de rattachement
              par défaut: période de paie . premier jour du mois bulletin
            date de fin de période de rattachement:
              titre: S21.G00.78.003 - Date de fin de période de rattachement
              par défaut: période de paie . dernier jour du mois bulletin
            montant: 
              titre: S21.G00.78.004 - Montant
              valeur: salarié . cotisations . assiette
              arrondi: 2 décimales
            identifiant technique d'affiliation: "''"
            numéro de contrat: salarié . contrat . numéro de contrat
            # 79
            smic: 
              non applicable si:
                une de ces conditions:
                  - salarié . contrat . stage
                  - dirigeant
              avec:
                type de composant de base assujettie: "'01'"
                montant de composant de base assujettie:
                  valeur: salarié . temps de travail . réduction générale cotisations . SMIC
                  arrondi: 2 décimales
            taxe sur les salaires: 
              applicable si: salarié . cotisations . taxe sur les salaires
              avec:
                type de composant de base assujettie: "'91'"
                montant de composant de base assujettie:
                  valeur: salarié . cotisations . taxe sur les salaires . assiette
                  arrondi: 2 décimales
            # 81
            cotisation individuelle:
              avec:
                # RETRAITE 105:
                #   avec:
                #     code de cotisation individuelle: "'105'" #001
                #     identifiant Organisme de Protection Sociale: "''" #002
                #     montant d'assiette: "''" #003
                #     montant de cotisation:   #004
                #       variations:
                #         - si: salarié . contrat . stage
                #           alors: 0
                #         - sinon: 0
                #             # somme:
                #             #   - salarié . cotisations . CEG
                #             #   - salarié . cotisations . CET
                #             #   - salarié . cotisations . retraite complémentaire
                #             #   - salarié . cotisations . APEC
                #       arrondi: 2 décimales
                #     taux de cotisation:  #007
                RETRAITE 131:
                  avec:
                    code de cotisation individuelle: "'131'" #001
                    identifiant Organisme de Protection Sociale: "''" #002
                    montant d'assiette: "''" #003
                    montant de cotisation:   #004
                      variations:
                        - si: salarié . contrat . stage
                          alors: "'0.00'"
                        - sinon:
                            somme:
                              - salarié . cotisations . CEG . employeur . montant T2
                              - salarié . cotisations . CEG . salarié . montant T2
                              - salarié . cotisations . CET
                              - salarié . cotisations . retraite complémentaire . employeur . montant T2
                              - salarié . cotisations . retraite complémentaire . salarié . montant T2
                              # - salarié . cotisations . APEC
                      arrondi: 2 décimales
                    taux de cotisation:  #007
                RETRAITE 132:
                  applicable si: 
                    une de ces conditions:
                      - salarié . cotisations . APEC > 0
                      - salarié . cotisations . APEC < 0
                  avec:
                    code de cotisation individuelle: "'132'" #001
                    identifiant Organisme de Protection Sociale: "''" #002
                    montant d'assiette: "''" #003
                    montant de cotisation:   #004
                      variations:
                        - si: salarié . contrat . stage
                          alors: "'0.00'"
                        - sinon:
                            valeur: salarié . cotisations . APEC
                      arrondi: 2 décimales
                    taux de cotisation:  #007
                ATMP 045:
                  avec:
                    code de cotisation individuelle: "'045'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: salarié . cotisations . ATMP  #004
                      arrondi: 2 décimales
                    taux de cotisation: 
                      valeur: salarié . cotisations . ATMP . taux * 100 #007
                      arrondi: 2 décimales
                CSA 068:
                  avec:
                    code de cotisation individuelle: "'068'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: salarié . cotisations . CSA  #004
                      arrondi: 2 décimales
                    taux de cotisation: 
                      valeur: salarié . cotisations . CSA . taux * 100 #007
                      arrondi: 2 décimales
                AF 074:
                  avec:
                    code de cotisation individuelle: "'074'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: salarié . cotisations . allocations familiales . montant taux réduit  #004
                      arrondi: 2 décimales
                    taux de cotisation: 
                      valeur: salarié . cotisations . allocations familiales . taux . taux 2 * 100 #007
                      arrondi: 2 décimales
                AF COMPLEMENT 102:
                  non applicable si: salarié . cotisations . allocations familiales . taux réduit
                  avec:
                    code de cotisation individuelle: "'102'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      somme: 
                        - salarié . cotisations . allocations familiales . montant complément . base #003
                        - salarié . cotisations . allocations familiales JEI non exo . base
                      arrondi: 2 décimales
                    montant de cotisation: 
                      somme: 
                        - salarié . cotisations . allocations familiales . montant complément  #004
                        - salarié . cotisations . allocations familiales JEI non exo
                      arrondi: 2 décimales
                    taux de cotisation: 
                      somme: 
                        - salarié . cotisations . allocations familiales . taux . taux complément * 100 #007
                        - salarié . cotisations . allocations familiales JEI non exo . taux
                      arrondi: 2 décimales
                MALADIE ALSACE MOSELLE 115:
                  applicable si: salarié . régimes spécifiques . alsace moselle
                  avec:
                    code de cotisation individuelle: "'115'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: salarié . cotisations . maladie . salarié #004
                      arrondi: 2 décimales
                    taux de cotisation: 
                      valeur: salarié . cotisations . maladie . salarié . taux * 100 #007
                      arrondi: 2 décimales
                MALADIE 075:
                  avec:
                    code de cotisation individuelle: "'075'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      somme: 
                        - salarié . cotisations . maladie . employeur . base #003
                        # - salarié . cotisations . maladie JEI non exo . base
                      arrondi: 2 décimales
                    montant de cotisation: 
                      somme: 
                        - salarié . cotisations . maladie . employeur . montant cotisations taux réduit 
                        - salarié . cotisations . maladie . salarié
                        # - salarié . cotisations . maladie JEI non exo . salarié
                      arrondi: 2 décimales
                    taux de cotisation: #007
                      somme:
                        - salarié . cotisations . maladie . employeur . taux . taux 2 * 100
                        - salarié . cotisations . maladie . salarié . taux * 100
                        # - salarié . cotisations . maladie JEI non exo . salarié . taux * 100
                      arrondi: 2 décimales
                VIELLESSE DEPLAFONNEE 076:
                  non applicable si: salarié . contrat . apprentissage
                  avec:
                    code de cotisation individuelle: "'076'"
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET
                    montant d'assiette: 
                      somme: 
                        - salarié . cotisations . vieillesse . base déplafonnée
                        - salarié . cotisations . vieillesse JEI non exo . employeur . déplafonnée . base
                      arrondi: 2 décimales
                    montant de cotisation: 
                      somme:
                        - salarié . cotisations . vieillesse . employeur . déplafonnée
                        - salarié . cotisations . vieillesse . salarié . déplafonnée
                        - salarié . cotisations . vieillesse JEI non exo . employeur . déplafonnée
                        - salarié . cotisations . vieillesse JEI non exo . salarié . déplafonnée
                      arrondi: 2 décimales
                    taux de cotisation: 
                      somme:
                        - salarié . cotisations . vieillesse . employeur . déplafonnée . taux * 100
                        - salarié . cotisations . vieillesse . salarié . déplafonnée . taux * 100
                        - salarié . cotisations . vieillesse JEI non exo . salarié . déplafonnée . taux * 100
                        - salarié . cotisations . vieillesse JEI non exo . employeur . déplafonnée . taux * 100
                      arrondi: 2 décimales
                VIEILLESSE DEPLAFONNEE APPRENTIS EXO:
                  applicable si: salarié . contrat . apprentissage
                  avec:
                    code de cotisation individuelle: "'076'"
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET
                    montant d'assiette: salarié . cotisations . assiette - salarié . contrat . apprentissage . assiette réduite apprentissage
                    montant de cotisation: 
                      valeur: montant d'assiette * 2.02%
                      arrondi: 2 décimales
                    taux de cotisation: "'2.02'"
                VIEILLESSE DEPLAFONNEE APPRENTIS NON EXO:
                  applicable si: salarié . contrat . apprentissage
                  avec:
                    code de cotisation individuelle: "'076'"
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET
                    montant d'assiette: salarié . contrat . apprentissage . assiette réduite apprentissage
                    montant de cotisation: 
                      valeur: montant d'assiette * 2.42%
                      arrondi: 2 décimales
                    taux de cotisation: "'2.42'"
                DIALOGUE SOCIAL 100:
                  avec:
                    code de cotisation individuelle: "'100'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: salarié . cotisations . contribution au dialogue social  #004
                      arrondi: 2 décimales
                    taux de cotisation: 
                      valeur: "'0.016'" #007
                      arrondi: 4 décimales
                CFP 128:
                  avec:
                    code de cotisation individuelle: "'128'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: salarié . cotisations . formation professionnelle  #004
                      arrondi: 2 décimales
                    taux de cotisation: 
                      valeur: salarié . cotisations . formation professionnelle . taux * 100 #007
                      arrondi: 2 décimales
                APPRENTISSAGE PRINCIPAL 130:
                  avec:
                    code de cotisation individuelle: "'130'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . taxe d'apprentissage . part principale . base #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: salarié . cotisations . taxe d'apprentissage . part principale  #004
                      arrondi: 2 décimales
                    taux de cotisation: 
                      valeur: salarié . cotisations . taxe d'apprentissage . part principale . taux * 100 #007
                      arrondi: 2 décimales
                COMPLEMENT MALADIE 907:
                  non applicable si: salarié . cotisations . maladie . employeur . taux réduit
                  avec:
                    code de cotisation individuelle: "'907'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      somme: 
                        - salarié . cotisations . maladie . employeur . montant cotisations complément . base #003
                        - salarié . cotisations . maladie JEI non exo . employeur . base
                      arrondi: 2 décimales
                    montant de cotisation: 
                      somme: 
                        - salarié . cotisations . maladie . employeur . montant cotisations complément  #004
                        - salarié . cotisations . maladie JEI non exo . employeur
                      arrondi: 2 décimales
                    taux de cotisation: 
                      somme: 
                        - salarié . cotisations . maladie . employeur . montant cotisations complément . taux * 100 #007
                        - salarié . cotisations . maladie JEI non exo . employeur . taux * 100
                      arrondi: 2 décimales
                RGCP URSSAF 018:
                  non applicable si: 
                    une de ces conditions:
                      - dirigeant
                      - salarié . contrat . stage
                      - salarié . cotisations . statut JEI
                      - salarié . cotisations . exonérations . réduction générale . cotisations patronales = 0
                  avec:
                    code de cotisation individuelle: "'018'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: 0 - salarié . cotisations . exonérations . réduction générale . cotisations patronales #004
                      arrondi: 2 décimales
                RGCP RETRAITE 106:
                  non applicable si: 
                    une de ces conditions:
                      - dirigeant
                      - salarié . contrat . stage
                      - salarié . cotisations . statut JEI
                      - salarié . cotisations . exonérations . réduction générale . cotisations patronales retraites = 0
                  avec:
                    code de cotisation individuelle: "'106'" #001
                    identifiant Organisme de Protection Sociale: "''"
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: 0 - salarié . cotisations . exonérations . réduction générale . cotisations patronales retraites #004
                      arrondi: 2 décimales
                DEDUCTION PATRONALE HS 021:
                  applicable si: salarié . cotisations . exonérations . heures supplémentaires . employeur
                  avec:
                    code de cotisation individuelle: "'021'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: (salarié . traitement en paie . temps . heures supplémentaires-complémentaires - salarié . heures complémentaires . nombre + salarié . traitement en paie . temps . heures dimanche-nuit-jours fériés + salarié . rémunération . rachat RTT . exonération d'heures supplémentaires . employeur)
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: 0 - salarié . cotisations . exonérations . heures supplémentaires . employeur
                      arrondi: 2 décimales
                EXONERATION HS 114:
                  applicable si: salarié . cotisations . exonérations . heures supplémentaires . salarié
                  avec:
                    code de cotisation individuelle: "'114'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . exonérations . heures supplémentaires . salarié . base
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: 0 - salarié . cotisations . exonérations . heures supplémentaires . salarié
                      arrondi: 2 décimales
                EXONERATION URSSAF APPRENTIS:
                  applicable si: salarié . contrat . apprentissage
                  avec:
                    code de cotisation individuelle:
                      variations:
                        - si: 
                            toutes ces conditions:
                              - entreprise . salariés . effectif @{ A } > 10
                              - entreprise . salariés . effectif @{ A-1 } > 10
                              - entreprise . salariés . effectif @{ A-2 } > 10
                              - entreprise . salariés . effectif @{ A-3 } > 10
                              - entreprise . salariés . effectif @{ A-4 } > 10
                              - entreprise . salariés . effectif @{ A-5 } > 10
                          alors: "'002'"
                        - sinon: "'001'"
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET #002
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette - salarié . contrat . apprentissage . assiette réduite apprentissage
                      arrondi: 2 décimales
                EXONERATION RETRAITE APPRENTIS:
                  applicable si: salarié . contrat . apprentissage
                  avec:
                    code de cotisation individuelle: "'109'"
                    identifiant Organisme de Protection Sociale: "''"
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette - salarié . contrat . apprentissage . assiette réduite apprentissage
                      arrondi: 2 décimales
                EXONERATION JEI 014:
                  applicable si: salarié . cotisations . statut JEI
                  avec:
                    code de cotisation individuelle: "'014'" #001
                    identifiant Organisme de Protection Sociale: entreprise . urssaf . SIRET
                    montant d'assiette: 
                      valeur: salarié . cotisations . vieillesse JEI exo . employeur . déplafonnée . base
                      arrondi: 2 décimales
                EXONERATION STAGE 022:
                  applicable si: salarié . contrat . stage
                  avec:
                    code de cotisation individuelle: "'022'" #001
                    identifiant Organisme de Protection Sociale: "''"
                    montant d'assiette: 
                      valeur: salarié . contrat . stage . exonération de cotisations #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: "''" #004
                FORMATION PROFESSIONNELLE CONVENTIONNELLE 141:
                  avec:
                    code de cotisation individuelle: "'141'" #001
                    identifiant Organisme de Protection Sociale: "''"
                    montant d'assiette: 
                      valeur: salarié . cotisations . assiette #003
                      arrondi: 2 décimales
                    montant de cotisation: 
                      valeur: salarié . cotisations . formation professionnelle . conventionnel #004
        assiette brute plafonnée 02:
          avec:
            # 78
            code: "'02'"
            date de début de période de rattachement:
              titre: S21.G00.78.002 - Date de début de période de rattachement
              par défaut: période de paie . premier jour du mois bulletin
            date de fin de période de rattachement:
              titre: S21.G00.78.003 - Date de fin de période de rattachement
